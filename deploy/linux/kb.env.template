KB_ENV=prod

# 数据库
KB_DB_HOST=127.0.0.1
KB_DB_PORT=3306
KB_DB_NAME=kb
KB_DB_USER=kb_user
KB_DB_PASSWORD=change_me

# Redis
KB_REDIS_HOST=127.0.0.1
KB_REDIS_PORT=6379
KB_REDIS_PASSWORD=

# Elasticsearch
KB_ES_ENABLED=true
KB_ES_HOST=http://127.0.0.1:9200
KB_ES_ENDPOINT=http://127.0.0.1:9200
KB_ES_URIS=http://127.0.0.1:9200
KB_ES_INDEX=kb_chunk

# Qdrant
KB_VECTOR_ENABLED=true
KB_QDRANT_HOST=127.0.0.1
KB_QDRANT_PORT=6333
KB_QDRANT_ENDPOINT=http://127.0.0.1:6333
KB_QDRANT_COLLECTION=kb_chunk
KB_QDRANT_TIMEOUT_SECONDS=10
KB_EMBEDDING_MODEL=mock-embedding-v1
KB_EMBEDDING_DIM=1024

# MinIO
KB_MINIO_ENDPOINT=http://127.0.0.1:9000
KB_MINIO_ACCESS_KEY=minioadmin
KB_MINIO_SECRET_KEY=minioadmin123

# 大模型网关
KB_LLM_ENABLED=false
KB_LLM_FAIL_OPEN=true
KB_LLM_BASE_URL=
KB_LLM_API_KEY=
KB_LLM_MODEL=
KB_LLM_AUTH_HEADER_NAME=Authorization
KB_LLM_AUTH_HEADER_PREFIX=Bearer 
KB_LLM_ORG_HEADER_NAME=
KB_LLM_ORG_HEADER_VALUE=
KB_LLM_WORKSPACE_HEADER_NAME=
KB_LLM_WORKSPACE_HEADER_VALUE=
KB_LLM_CONTENT_PATH=choices[0].message.content
KB_LLM_ERROR_CODE_PATH=error.code
KB_LLM_ERROR_MESSAGE_PATH=error.message

# Worker 运行参数
KB_WORKER_POLL_INTERVAL_SECONDS=5
KB_WORKER_BATCH_SIZE=5
KB_WORKER_DOWNLOAD_DIR=/app/kb/parser-worker/tmp/downloads
KB_WORKER_UPLOAD_ROOT=/data/kb/uploads
