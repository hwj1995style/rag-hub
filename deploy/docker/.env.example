KB_TIMEZONE=Asia/Shanghai

# MySQL
KB_DB_NAME=kb
KB_DB_USER=kb_user
KB_DB_PASSWORD=change_me
KB_DB_ROOT_PASSWORD=root_change_me
KB_DB_PORT_HOST=13306

# Redis
KB_REDIS_PASSWORD=change_me
KB_REDIS_PORT_HOST=6379

# MinIO
KB_MINIO_ACCESS_KEY=minioadmin
KB_MINIO_SECRET_KEY=minioadmin123
KB_MINIO_API_PORT_HOST=9000
KB_MINIO_CONSOLE_PORT_HOST=9001

# Elasticsearch
KB_ES_INDEX=kb_chunk
KB_ES_PORT_HOST=9200
KB_ES_ENABLED=true
KB_ES_JAVA_OPTS=-Xms1g -Xmx1g

# Qdrant
KB_QDRANT_COLLECTION=kb_chunk
KB_QDRANT_HTTP_PORT_HOST=6333
KB_QDRANT_GRPC_PORT_HOST=6334
KB_VECTOR_ENABLED=true
KB_EMBEDDING_MODEL=mock-embedding-v1
KB_EMBEDDING_DIM=1024

# Backend / Nginx
KB_BACKEND_PORT_HOST=8080
KB_NGINX_PORT_HOST=80

# 大模型网关
KB_LLM_ENABLED=false
KB_LLM_FAIL_OPEN=true

# Optional bootstrap admin for first-time Docker verification or local demos
KB_BOOTSTRAP_ADMIN_ENABLED=false
KB_BOOTSTRAP_ADMIN_USERNAME=admin
KB_BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
KB_BOOTSTRAP_ADMIN_DISPLAY_NAME=Local Admin
KB_BOOTSTRAP_ADMIN_ROLE_CODE=admin
